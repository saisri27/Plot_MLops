# =============================================================================
# Plot App — Environment Variables
# =============================================================================
# HOW TO USE:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in your real values in .env
#   3. NEVER commit .env — it's in .gitignore
#
# For Cloud Run deployment, set these same variables in:
#   GCP Console → Cloud Run → your service → Edit → Variables & Secrets
# =============================================================================


# -----------------------------------------------------------------------------
# SUPABASE (free database — get at https://supabase.com)
#
# Postgres (FastAPI / db.py, scripts):
#   Dashboard → Project Settings → Database → Connection string → Session pooler
#
# Browser / Next.js client (public — safe to embed in frontend):
#   Dashboard → Project Settings → API → Project URL + anon (or publishable) key
#   Prefix NEXT_PUBLIC_ only for Next.js; never put service_role in NEXT_PUBLIC_.
# -----------------------------------------------------------------------------
DATABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# If your Supabase dashboard labels it "Publishable key", use the same value:
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_key_here


# -----------------------------------------------------------------------------
# GOOGLE CLOUD PLATFORM
# -----------------------------------------------------------------------------
GCP_PROJECT=mlops-project-491402
BQ_DATASET=places_raw
BQ_TABLE=venues
BQ_EVENTS_TABLE=events

# Path to your GCP service account key (for local dev only)
# On Cloud Run this is handled automatically via Workload Identity — leave blank
GOOGLE_APPLICATION_CREDENTIALS=


# -----------------------------------------------------------------------------
# DATA SCRAPING — Google Places API
# Get at: https://console.cloud.google.com → APIs → Places API (New)
# -----------------------------------------------------------------------------
GOOGLE_PLACES_API_KEY=



# -----------------------------------------------------------------------------
# DATA SCRAPING — Ticketmaster API
# Get at: https://developer.ticketmaster.com → My Apps
# -----------------------------------------------------------------------------
TICKETMASTER_API_KEY=
TICKETMASTER_SECRET=


# -----------------------------------------------------------------------------
# MLFLOW — Experiment tracking + model registry
# Running on your GCP VM (dateplan-ingest)
# Format: http://EXTERNAL_IP:5000
# -----------------------------------------------------------------------------
MLFLOW_TRACKING_URI=http://34.170.56.124:5000/
MLFLOW_EXPERIMENT_NAME=plot-venue-ranker


# -----------------------------------------------------------------------------
# OPENAI — LLM reranker (optional)
# Get at: https://platform.openai.com/api-keys
# If unset, /recommend silently falls back to v0 heuristic ranking.
# Cost expectation with gpt-4o-mini: ~$0.0005 per /recommend call.
# -----------------------------------------------------------------------------
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# FASTAPI — Decision engine settings
# -----------------------------------------------------------------------------
# How many venues to return by default
DEFAULT_TOP_K=5

# Environment tag (used in logs + monitoring)
ENV=development


# -----------------------------------------------------------------------------
# SCRAPING CONFIG (optional overrides)
# -----------------------------------------------------------------------------
USE_GRID=true
